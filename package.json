{
  "name": "numbers-transition",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/numbers-transition.cjs",
  "module": "./dist/numbers-transition.js",
  "types": "./dist/numbers-transition.d.ts",
  "exports": {
    ".": {
      "types": "./dist/numbers-transition.d.ts",
      "import": "./dist/numbers-transition.js",
      "require": "./dist/numbers-transition.cjs"
    }
  },
  "scripts": {
    "prepare": "ts-patch install -s && husky",
    "lint": "eslint . --max-warnings 0",
    "build:plugins": "tsc -p tsconfig.plugins.json && vite build -c vite.plugins.ts",
    "verify:plugins": "npm run build:plugins && tsc -p tsconfig.plugins.test.json && vitest -c vite.plugins.test.ts run",
    "storybook": "npm run build:plugins && storybook dev -p 6006",
    "build": "npm run verify:plugins && tsc && vite build",
    "build:storybook": "npm run build && storybook build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "styled-components": ">=6.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.7",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "storybook": "^10.3.6",
    "terser": "^5.47.1",
    "ts-patch": "^4.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "unplugin-dts": "^1.0.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
